<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F5F7">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottomNav">

        <LinearLayout
            android:id="@+id/main"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- TOP BAR -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:background="#000B36"
                android:gravity="center_vertical"
                android:paddingTop="18dp"
                android:paddingBottom="12dp">

                <ImageView
                    android:layout_width="200dp"
                    android:layout_height="58dp"
                    android:src="@drawable/top_logo"
                    />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Profile Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingTop="20dp"
                    android:paddingBottom="24dp">

                    <RelativeLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">

                        <androidx.cardview.widget.CardView
                            android:id="@+id/cvProfilePicHeader"
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            app:cardCornerRadius="50dp"
                            app:cardElevation="4dp">

                            <ImageView
                                android:id="@+id/ivProfileLarge"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@drawable/user_profile"
                                android:scaleType="centerCrop"/>
                        </androidx.cardview.widget.CardView>

                        <ImageView
                            android:id="@+id/btnChangePic"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_alignBottom="@id/cvProfilePicHeader"
                            android:layout_alignEnd="@id/cvProfilePicHeader"
                            android:background="@drawable/circle_bg"
                            android:backgroundTint="#000000"
                            android:padding="6dp"
                            android:src="@drawable/icon_edit"
                            app:tint="#FFFFFF"
                            android:elevation="6dp"/>
                    </RelativeLayout>

                    <TextView
                        android:id="@+id/tvProfileName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Alex Rivers"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="#0D1B2A"
                        android:layout_marginTop="12dp"/>

                    <TextView
                        android:id="@+id/tvProfileRole"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Attendee"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:background="@drawable/badge_attendee_bg"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>

                <!-- SELECT AVATAR -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="SELECT AVATAR"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:textColor="#666666"/>
                </LinearLayout>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginBottom="24dp">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Gallery Add -->
                        <LinearLayout
                            android:id="@+id/btnGallery"
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:background="@drawable/avatar_add_bg"
                            android:gravity="center">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/icon_edit"
                                app:tint="#666666"/>
                        </LinearLayout>

                        <!-- Avatar Default (user_profile) -->
                        <FrameLayout
                            android:id="@+id/flAvatarDefault"
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:layout_marginStart="12dp"
                            android:background="@drawable/avatar_frame_bg"
                            android:padding="4dp">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@drawable/user_profile"
                                android:scaleType="centerCrop"/>
                        </FrameLayout>

                        <!-- Avatar Male -->
                        <FrameLayout
                            android:id="@+id/flAvatarMale"
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:layout_marginStart="12dp"
                            android:background="@drawable/avatar_frame_bg"
                            android:padding="4dp">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@drawable/male_profile"
                                android:scaleType="centerCrop"/>
                        </FrameLayout>

                        <!-- Avatar Female -->
                        <FrameLayout
                            android:id="@+id/flAvatarFemale"
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:layout_marginStart="12dp"
                            android:background="@drawable/avatar_frame_bg"
                            android:padding="4dp">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@drawable/female_profile"
                                android:scaleType="centerCrop"/>
                        </FrameLayout>

                    </LinearLayout>
                </HorizontalScrollView>

                <!-- INPUT FIELDS -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Full Name"
                    android:textStyle="bold"
                    android:textColor="#0D1B2A"
                    android:layout_marginBottom="8dp"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/edittext_bg"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    android:layout_marginBottom="16dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/icon_name"
                        app:tint="#888888"/>
                    <EditText
                        android:id="@+id/etName"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:hint="Full Name"
                        android:textSize="15sp"
                        android:paddingStart="12dp"
                        android:inputType="textPersonName"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email Address"
                    android:textStyle="bold"
                    android:textColor="#0D1B2A"
                    android:layout_marginBottom="8dp"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/edittext_locked_bg"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    android:layout_marginBottom="16dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/icon_email"
                        app:tint="#888888"/>
                    <EditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:enabled="false"
                        android:textSize="15sp"
                        android:paddingStart="12dp"
                        android:textColor="#555555"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bio"
                    android:textStyle="bold"
                    android:textColor="#0D1B2A"
                    android:layout_marginBottom="8dp"/>
                <EditText
                    android:id="@+id/etBio"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:background="@drawable/edittext_bg"
                    android:gravity="top"
                    android:padding="12dp"
                    android:hint="Tell us about yourself..."
                    android:textSize="14sp"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Phone"
                    android:textStyle="bold"
                    android:textColor="#0D1B2A"
                    android:layout_marginBottom="8dp"/>
                <EditText
                    android:id="@+id/etPhone"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/edittext_bg"
                    android:paddingHorizontal="12dp"
                    android:hint="Phone Number"
                    android:inputType="phone"
                    android:textSize="15sp"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Country"
                    android:textStyle="bold"
                    android:textColor="#0D1B2A"
                    android:layout_marginBottom="8dp"/>
                <EditText
                    android:id="@+id/etCountry"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/edittext_bg"
                    android:paddingHorizontal="12dp"
                    android:hint="Country"
                    android:textSize="15sp"
                    android:layout_marginBottom="24dp"/>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Account Role"
                        android:textStyle="bold"
                        android:textColor="#666666"/>
                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_alignParentEnd="true"
                        android:src="@drawable/security_icon"
                        app:tint="#888888"/>
                </RelativeLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/edittext_locked_bg"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    android:layout_marginBottom="32dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/verify_icon"
                        app:tint="#888888"/>
                    <TextView
                        android:id="@+id/tvAccountRole"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:paddingStart="12dp"
                        android:text="Attendee"
                        android:textColor="#555555"
                        android:textSize="15sp"/>
                </LinearLayout>

                <!-- SAVE BUTTON -->
                <LinearLayout
                    android:id="@+id/btnSave"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/btn_my_tickets_bg"
                    android:elevation="4dp"
                    android:gravity="center"
                    android:layout_marginBottom="24dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/icon_save"
                        app:tint="#FFFFFF"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Save Changes"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:layout_marginStart="12dp"/>
                </LinearLayout>

                <!-- BOTTOM ACTIONS -->
                <LinearLayout
                    android:id="@+id/btnsec"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/btn_security_bg"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:layout_marginBottom="12dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/security_icon"
                        app:tint="#0D1B2A"/>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Security Settings"
                        android:textColor="#0D1B2A"
                        android:textStyle="bold"
                        android:layout_marginStart="12dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=">"
                        android:textColor="#0D1B2A"
                        android:textSize="18sp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnlogout"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/btn_logout_bg"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:layout_marginBottom="40dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/logout_icon"
                        app:tint="#D32F2F"/>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Log Out"
                        android:textColor="#D32F2F"
                        android:textStyle="bold"
                        android:layout_marginStart="12dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=">"
                        android:textColor="#D32F2F"
                        android:textSize="18sp"/>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>


    <!-- BOTTOM NAVIGATION -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        android:elevation="12dp"
        android:orientation="horizontal"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <!-- EVENTS -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="80dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                >

                <ImageView
                    android:id="@+id/btnmain"
                    android:layout_width="35dp"
                    android:layout_height="35dp"
                    android:src="@drawable/event_grey" />


            </LinearLayout>
        </LinearLayout>

        <!-- MY TICKETS -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/btnticket"
                android:layout_width="55dp"
                android:layout_height="60dp"
                android:src="@drawable/nav_grey_ticket" />
        </LinearLayout>

        <!-- DASHBOARD ACTIVE -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"

            android:orientation="vertical">

            <ImageView
                android:id="@+id/btndashboard"
                android:layout_width="55dp"
                android:layout_height="40dp"
                android:src="@drawable/nav_grey_dashboard" />

        </LinearLayout>

        <!-- PROFILE -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:background="@drawable/nav_bg"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/btnprofile"
                android:layout_width="55dp"
                android:layout_height="40dp"
                android:src="@drawable/nav_ligth_profile" />

        </LinearLayout>

    </LinearLayout>

</RelativeLayout>