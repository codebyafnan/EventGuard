<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F5F7">

    <!-- SCROLLABLE CONTENT -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottomNav"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/main"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:background="#000B36"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="18dp"
                android:paddingBottom="12dp">

                <ImageView
                    android:layout_width="180dp"
                    android:layout_height="58dp"
                    android:src="@drawable/top_logo"
                    />

                <View
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1" />

            </LinearLayout>

            <!-- PAGE CONTENT -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- PROFILE CARD -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardUseCompatPadding="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="24dp">

                        <!-- Profile Pic with Verified Badge -->
                        <RelativeLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">

                            <androidx.cardview.widget.CardView
                                android:id="@+id/cvProfilePic"
                                android:layout_width="90dp"
                                android:layout_height="90dp"
                                app:cardCornerRadius="45dp"
                                app:cardElevation="0dp"
                                android:layout_centerHorizontal="true">

                                <ImageView
                                    android:id="@+id/ivDashProfile"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:src="@drawable/user_profile"
                                    android:scaleType="centerCrop"/>
                            </androidx.cardview.widget.CardView>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Verified"
                                android:textColor="#FFFFFF"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:background="@drawable/badge_verified_bg"
                                android:layout_below="@id/cvProfilePic"
                                android:layout_centerHorizontal="true"
                                android:layout_marginTop="-12dp"
                                android:elevation="2dp"/>
                        </RelativeLayout>

                        <TextView
                            android:id="@+id/tvDashName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Alex Rivers"
                            android:textStyle="bold"
                            android:textSize="26sp"
                            android:textColor="#0D1B2A"
                            android:layout_marginTop="16dp"/>

                        <TextView
                            android:id="@+id/tvDashRole"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Attendee"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:background="@drawable/badge_attendee_bg"
                            android:layout_marginTop="8dp"/>

                        <TextView
                            android:id="@+id/tvDashJoinedEvents"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Joined January 2024 • 00 Events\nAttended"
                            android:textColor="#555555"
                            android:textSize="14sp"
                            android:gravity="center"
                            android:lineSpacingExtra="4dp"
                            android:layout_marginTop="12dp"/>

                        <!-- BUTTONS -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="24dp">

                            <LinearLayout
                                android:id="@+id/btn_ticket_card"
                                android:layout_width="0dp"
                                android:layout_height="48dp"
                                android:layout_weight="1"
                                android:background="@drawable/btn_my_tickets_bg"
                                android:gravity="center"
                                android:clickable="true"
                                android:focusable="true">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@drawable/ticket_icon"
                                    app:tint="#FFFFFF"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="My Tickets"
                                    android:textColor="#FFFFFF"
                                    android:textStyle="bold"
                                    android:textSize="15sp"
                                    android:layout_marginStart="8dp"/>
                            </LinearLayout>

                            <Space
                                android:layout_width="12dp"
                                android:layout_height="wrap_content"/>

                            <LinearLayout
                                android:id="@+id/btnEventCard"
                                android:layout_width="0dp"
                                android:layout_height="48dp"
                                android:layout_weight="1.2"
                                android:background="@drawable/btn_find_events_bg"
                                android:gravity="center"
                                android:clickable="true"
                                android:focusable="true">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@drawable/icon_search"
                                    app:tint="#0D1B2A"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Find Events"
                                    android:textColor="#0D1B2A"
                                    android:textStyle="bold"
                                    android:textSize="15sp"
                                    android:layout_marginStart="8dp"/>
                            </LinearLayout>
                        </LinearLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- ACTIVE TICKETS -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardUseCompatPadding="false">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvDashTicketCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="00"
                            android:textStyle="bold"
                            android:textSize="38sp"
                            android:textColor="#111111"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ACTIVE TICKETS"
                            android:textStyle="bold"
                            android:textSize="12sp"
                            android:textColor="#888888"/>
                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- PROFILE INFO TITLE -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Profile Info"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="#222222"
                    android:layout_marginBottom="10dp"/>

                <!-- PROFILE INFO CARD -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardUseCompatPadding="true"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="EMAIL ADDRESS"
                            android:textColor="#888888"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvDashEmail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="14dp"
                            android:text="email@example.com"
                            android:textColor="#222222"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="BIO"
                            android:textColor="#888888"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvDashBio"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="14dp"
                            android:text="Senior event coordinator with over 8 years of experience."
                            android:textColor="#222222"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PHONE"
                            android:textColor="#888888"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvDashPhone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="14dp"
                            android:text="+1 (555) 012-3456"
                            android:textColor="#222222"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Country"
                            android:textColor="#888888"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvDashLocation"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="18dp"
                            android:text="San Francisco, CA"
                            android:textColor="#222222"
                            android:textSize="14sp" />

                        <LinearLayout
                            android:id="@+id/btnProSet"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:background="@drawable/btn_edit_profile_bg"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/icon_edit"
                                app:tint="#000000" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="Edit Profile"
                                android:textColor="#000000"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- BOTTOM NAVIGATION -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        android:elevation="12dp"
        android:orientation="horizontal"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <!-- EVENTS -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="80dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                >

                <ImageView
                    android:id="@+id/btnmain"
                    android:layout_width="35dp"
                    android:layout_height="35dp"
                    android:src="@drawable/event_grey" />


            </LinearLayout>
        </LinearLayout>

        <!-- MY TICKETS -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/btnticket"
                android:layout_width="55dp"
                android:layout_height="60dp"
                android:src="@drawable/nav_grey_ticket" />
        </LinearLayout>

        <!-- DASHBOARD ACTIVE -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:background="@drawable/nav_bg"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/btndashboard"
                android:layout_width="55dp"
                android:layout_height="40dp"
                android:src="@drawable/nav_ligth_dashboard" />

        </LinearLayout>

        <!-- PROFILE -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/btnprofile"
                android:layout_width="55dp"
                android:layout_height="40dp"
                android:src="@drawable/nav_grey_profile" />

        </LinearLayout>

    </LinearLayout>
</RelativeLayout>