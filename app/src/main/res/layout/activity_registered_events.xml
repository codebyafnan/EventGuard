<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/screen_background"
    tools:context="UserModule.ticket.registered_events">

    <!-- SCROLLABLE CONTENT -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomNav"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/main"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- TOP BAR -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:background="#000B36"
                android:gravity="center_vertical"
                android:paddingTop="18dp"
                android:paddingBottom="12dp">

                <ImageView
                    android:layout_width="200dp"
                    android:layout_height="58dp"
                    android:src="@drawable/top_logo"
                    />

            </LinearLayout>

            <!-- TITLE -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="18dp"
                android:paddingTop="22dp"
                android:paddingBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Registered Events"
                    android:textColor="@color/primary_text"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Access your event passes quickly"
                    android:textColor="@color/secondary_text"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRegisteredEvents"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:paddingBottom="24dp"/>

        </LinearLayout>

    </ScrollView>

    <!-- BOTTOM NAVIGATION -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_alignParentBottom="true"
        android:background="@color/card_background"
        android:elevation="12dp"
        android:orientation="horizontal"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <!-- EVENTS -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="80dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                >

                <ImageView
                    android:id="@+id/btnmain"
                    android:layout_width="35dp"
                    android:layout_height="35dp"
                    android:src="@drawable/event_grey" />


            </LinearLayout>
        </LinearLayout>

        <!-- MY TICKETS -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:background="@drawable/nav_bg"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/btnticket"
                android:layout_width="55dp"
                android:layout_height="60dp"
                android:src="@drawable/nav_ligth_ticket" />
        </LinearLayout>

        <!-- DASHBOARD ACTIVE -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/btndashboard"
                android:layout_width="55dp"
                android:layout_height="40dp"
                android:src="@drawable/nav_grey_dashboard" />

        </LinearLayout>

        <!-- PROFILE -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/btnprofile"
                android:layout_width="55dp"
                android:layout_height="40dp"
                android:src="@drawable/nav_grey_profile" />

        </LinearLayout>

    </LinearLayout>

</RelativeLayout>