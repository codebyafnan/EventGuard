<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F5F7">

    <!-- SCROLLABLE CONTENT -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomNav"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/main"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:background="#000B36"
                android:gravity="center_vertical"
                android:paddingTop="18dp"
                android:paddingBottom="12dp">

                <ImageView
                    android:layout_width="200dp"
                    android:layout_height="58dp"
                    android:src="@drawable/top_logo"
                    />

            </LinearLayout>

            <!-- Pass Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cvPassCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="869dp"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/event_detail_banner" />

                    <TextView
                        android:id="@+id/tvPassEventTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="14dp"
                        android:text="Global Tech Summit 2026"
                        android:textColor="#111111"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/ivQRCode"
                        android:layout_width="240dp"
                        android:layout_height="240dp"
                        android:layout_gravity="center"
                        android:layout_marginTop="10dp"
                        android:scaleType="centerCrop"/>

                    <TextView
                        android:id="@+id/tvStatusInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="One-time use only"
                        android:textColor="#777777"
                        android:textSize="14sp"
                        android:layout_gravity="center"
                        />

                    <!-- Download BUTTON -->
                    <LinearLayout
                        android:id="@+id/btnDownloadTicket"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="28dp"
                        android:background="#000000"
                        android:gravity="center"
                        android:orientation="horizontal">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_marginRight="10dp"
                            android:src="@drawable/save_icon" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Download Pass"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:layout_marginStart="8dp"/>
                    </LinearLayout>

                    <!-- Profile Card -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <!-- Title -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ATTENDEE"
                                android:textColor="#1F2A5A"
                                android:textStyle="bold"
                                android:textSize="14sp"/>

                            <!-- Name -->
                            <TextView
                                android:id="@+id/tvAttendeeName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Alex Rivers"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="#111111"
                                android:layout_marginTop="4dp"
                                android:layout_marginBottom="16dp"/>

                            <!-- LOCATION ROW -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <TextView
                                    android:layout_width="110dp"
                                    android:layout_height="wrap_content"
                                    android:text="Location"
                                    android:textStyle="bold"
                                    android:textColor="#555555"/>

                                <TextView
                                    android:id="@+id/tvDetailLocation"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Metro Exhibition Center"
                                    android:textColor="#111111"/>

                            </LinearLayout>

                            <!-- TIME ROW -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginTop="10dp">

                                <TextView
                                    android:layout_width="110dp"
                                    android:layout_height="wrap_content"
                                    android:text="Time"
                                    android:textStyle="bold"
                                    android:textColor="#555555"/>

                                <TextView
                                    android:id="@+id/tvDetailTime"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="09:00 AM"
                                    android:textColor="#111111"/>

                            </LinearLayout>

                            <!-- DATE ROW -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginTop="10dp">

                                <TextView
                                    android:layout_width="110dp"
                                    android:layout_height="wrap_content"
                                    android:text="Date"
                                    android:textStyle="bold"
                                    android:textColor="#555555"/>

                                <TextView
                                    android:id="@+id/tvPassDate"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Oct 24, 2026"
                                    android:textColor="#111111"/>



                            </LinearLayout>

                            <!-- Seats ROW -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginTop="10dp">

                                <TextView
                                    android:layout_width="110dp"
                                    android:layout_height="wrap_content"
                                    android:text="Seat/Zone"
                                    android:textStyle="bold"
                                    android:textColor="#555555"/>

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Main Hall • A12"
                                    android:textColor="#111111"/>



                            </LinearLayout>


                        </LinearLayout>

                    </androidx.cardview.widget.CardView>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>


    <!-- BOTTOM NAVIGATION -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        android:elevation="12dp"
        android:orientation="horizontal"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <!-- EVENTS -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="80dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                >

                <ImageView
                    android:id="@+id/btnmain"
                    android:layout_width="35dp"
                    android:layout_height="35dp"
                    android:src="@drawable/event_grey" />


            </LinearLayout>
        </LinearLayout>

        <!-- MY TICKETS -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:background="@drawable/nav_bg"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/btnticket"
                android:layout_width="55dp"
                android:layout_height="60dp"
                android:src="@drawable/nav_ligth_ticket" />
        </LinearLayout>

        <!-- DASHBOARD ACTIVE -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/btndashboard"
                android:layout_width="55dp"
                android:layout_height="40dp"
                android:src="@drawable/nav_grey_dashboard" />

        </LinearLayout>

        <!-- PROFILE -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/btnprofile"
                android:layout_width="55dp"
                android:layout_height="40dp"
                android:src="@drawable/nav_grey_profile" />

        </LinearLayout>

    </LinearLayout>

</RelativeLayout>