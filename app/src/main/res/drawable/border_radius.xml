<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Background color -->
    <solid android:color="#000000"/>

    <!-- Border -->
    <stroke
        android:width="1dp"
        android:color="#000000"/>

    <!-- Corner radius -->
    <corners android:radius="12dp"/>


    <!-- Optional padding -->
    <padding
        android:left="10dp"
        android:top="10dp"
        android:right="10dp"
        android:bottom="10dp"/>

</shape>